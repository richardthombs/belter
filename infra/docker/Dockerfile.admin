FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src

COPY BelterLife.Shared/ BelterLife.Shared/
COPY BelterLife.Admin/ BelterLife.Admin/
RUN dotnet publish BelterLife.Admin/BelterLife.Admin.csproj -c Release -o /app/publish

FROM mcr.microsoft.com/dotnet/aspnet:10.0
WORKDIR /app
COPY --from=build /app/publish .
# Admin API is internal only — never publicly exposed
EXPOSE 5002
ENTRYPOINT ["dotnet", "BelterLife.Admin.dll"]
